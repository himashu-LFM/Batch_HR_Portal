## This Lambda only needs DB + SES configuration.
## Do NOT put real secrets into .env.example.

## Database (required)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"
## If using AWS RDS Postgres, you typically need SSL
PGSSLMODE=require

## AWS / SES (required)
AWS_REGION=ap-south-1
SES_FROM_EMAIL=no-reply@hr.quintypeservices.com

## Testing safety (recommended for local tests)
## If set, ALL birthday/anniversary emails will be sent to this address instead of real employees.
TEST_TO_EMAIL=test@example.com

## Idempotency logging (required)
## Your schema requires automation_emails.sentById; set this to an existing users.id
SYSTEM_USER_ID=

## Optional behavior toggles
DRY_RUN=0
FORCE_RUN=0
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY